# ─────────────────────────────────────────────────────────────────────────────
# Default environment variables (committed to git — no secrets here)
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" to hit local backend (http://localhost:4050)
# Set to "false" or leave unset to hit the production backend
VITE_USE_LOCAL=false
VITE_LOCAL_API_URL=http://localhost:4050
VITE_PROD_API_URL=https://backend-nexusr.onrender.com

# Demo/mock mode — set to "false" to disable mock users and use real auth
VITE_ENABLE_DEMO=false
